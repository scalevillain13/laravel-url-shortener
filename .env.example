APP_NAME="Сокращатель ссылок"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- База данных ---
# Локально по умолчанию SQLite. В Docker используется тот же файл в volume.
DB_CONNECTION=sqlite
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=shortener
# DB_USERNAME=shortener
# DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120

# --- Очереди ---
# sync — клики пишутся сразу (удобно для разработки)
# database — асинхронно, нужен php artisan queue:work (или сервис queue в docker-compose)
QUEUE_CONNECTION=sync

CACHE_STORE=database

# --- Shortener ---
# Требовать HTTPS в оригинальных URL
SHORTENER_REQUIRE_HTTPS=true
# Лимит редиректов с одного IP (в минуту)
SHORTENER_REDIRECT_RATE_LIMIT=60
# Лимит выдачи API-токенов с одного IP (в минуту)
SHORTENER_API_TOKEN_RATE_LIMIT=5
# Лимит создания ссылок на публичном лендинге с одного IP (в минуту)
SHORTENER_HOME_STORE_RATE_LIMIT=10
# Не учитывать переходы ботов/crawler'ов
SHORTENER_IGNORE_BOTS=true
# Геолокация по IP (ip-api.com, выполняется в queue job)
SHORTENER_GEOIP_ENABLED=true

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
